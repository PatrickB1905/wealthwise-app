# Docker environment
# Copy to: /.env

# =============================================================================
# Database
# =============================================================================
POSTGRES_DB=wealthwise
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@db:5432/wealthwise

# =============================================================================
# Secrets
# =============================================================================
# Use a strong random value in real deployments (do not commit real secrets).
JWT_SECRET=add_your_jwt_secret_here

# =============================================================================
# External APIs
# =============================================================================
NEWS_API_KEY=add_your_news_api_key_here

# =============================================================================
# Analytics Service Configuration
# =============================================================================
ANALYTICS_PORT=7000

# =============================================================================
# Market Data Service Configuration
# =============================================================================
# Inside Docker, services talk to each other by service name (not localhost).
# market-data is the docker-compose service name.
MARKET_DATA_URL=http://market-data:5000/api

# =============================================================================
# Positions Data Service Configuration
# =============================================================================
POSITIONS_PORT=4000

# =============================================================================
# Frontend (Host Port) + CORS Origin
# =============================================================================
# The frontend runs inside Docker on port 80.
# Docker exposes it to your machine using the port defined below.
#
# This is the port you open in your browser:
#     http://localhost:<FRONTEND_PORT>
#
# Example:
#     FRONTEND_PORT=5173
#     -> Open http://localhost:5173
#
FRONTEND_PORT=5173

# This is the exact browser origin allowed by CORS.
# Must use the same port as FRONTEND_PORT.
FRONTEND_ORIGIN=http://localhost:${FRONTEND_PORT}

# =============================================================================
# Service URLs (used by the frontend at build time)
# =============================================================================
VITE_POSITIONS_API_URL=http://localhost:/api
VITE_MARKET_DATA_API_URL=http://localhost:5000/api
VITE_ANALYTICS_API_URL=http://localhost:${ANALYTICS_PORT}/api
VITE_NEWS_API_URL=http://localhost:6500/api