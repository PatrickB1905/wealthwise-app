# =============================================================================
# WealthWise — DOCKER environment
# =============================================================================
# Copy to:
#   .env
#
# This file is the single source of truth when running the full stack in Docker.
# =============================================================================

# =============================================================================
# Database (Docker)
# =============================================================================
POSTGRES_DB=wealthwise
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@db:5432/wealthwise

# =============================================================================
# Secrets
# =============================================================================
# Use a strong random value in real deployments (never commit real secrets).
JWT_SECRET=add_your_jwt_secret_here

# =============================================================================
# External APIs
# =============================================================================
NEWS_API_KEY=add_your_news_api_key_here

# =============================================================================
# Service ports (HOST -> Docker)
# =============================================================================
# These control which ports Docker exposes on your machine.
ANALYTICS_PORT=7000
POSITIONS_PORT=4000
FRONTEND_PORT=5173
MARKET_DATA_PORT=5000
NEWS_PORT=6500

# =============================================================================
# CORS / Browser origin
# =============================================================================
# Must match the port you open in your browser (FRONTEND_PORT).
FRONTEND_ORIGIN=http://localhost:${FRONTEND_PORT}

# =============================================================================
# Inter-service URLs (Docker network)
# =============================================================================
# Services talk to each other by docker-compose service name (not localhost).
MARKET_DATA_URL=http://market-data:${MARKET_DATA_PORT}/api

# =============================================================================
# Frontend build-time service URLs (your browser -> host ports)
# =============================================================================
VITE_POSITIONS_API_URL=http://localhost:${POSITIONS_PORT}/api
VITE_MARKET_DATA_API_URL=http://localhost:${MARKET_DATA_PORT}/api
VITE_ANALYTICS_API_URL=http://localhost:${ANALYTICS_PORT}/api
VITE_NEWS_API_URL=http://localhost:${NEWS_PORT}/api