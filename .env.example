# =============================================================================
# WealthWise — DOCKER environment
# =============================================================================
# Copy to:
#   .env
#
# This file is the single source of truth when running the full stack in Docker.
# =============================================================================

# =============================================================================
# Database (Docker)
# =============================================================================
POSTGRES_DB=wealthwise
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@db:5432/wealthwise

# =============================================================================
# Secrets
# =============================================================================
# Use a strong random value in real deployments (never commit real secrets).
JWT_SECRET=add_your_jwt_secret_here

# =============================================================================
# External APIs
# =============================================================================
NEWS_API_KEY=add_your_news_api_key_here
LOGO_DEV_TOKEN=add_your_logo_dev_token_here
LOGO_DEV_BASE_URL=https://img.logo.dev

# =============================================================================
# Service ports (HOST -> Docker)
# =============================================================================
# These control which ports Docker exposes on your machine.
ANALYTICS_SERVICE_PORT=7000
POSITIONS_SERVICE_PORT=4000
MARKET_DATA_SERVICE_PORT=5000
NEWS_SERVICE_PORT=6500
FRONTEND_HOST_PORT=5173

# Analytics cache for expensive calculations (yfinance calls)
ANALYTICS_CACHE_TTL_SECONDS=30
# Maximum lookback for performance/risk endpoints
ANALYTICS_MAX_DAYS=730

# =============================================================================
# CORS / Browser origin
# =============================================================================
# Must match the port you open in your browser (FRONTEND_HOST_PORT).
# FRONTEND_ORIGINS must be a comma separated list
FRONTEND_ORIGINS=http://localhost:5173, http://127.0.0.1:5173

# =============================================================================
# Inter-service URLs (Docker network)
# =============================================================================
# Services talk to each other by docker-compose service name (not localhost).
MARKET_DATA_SERVICE_URL=http://market-data:${MARKET_DATA_SERVICE_PORT}/api
POSITIONS_SERVICE_URL=http://positions:${POSITIONS_SERVICE_PORT}/api