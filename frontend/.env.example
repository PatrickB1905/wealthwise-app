# Frontend environment configuration (Vite)
# Copy this file to: frontend/.env.local
#
# WealthWise supports two run modes:
#
# 1) Docker / Production (recommended)
#    - Do NOT set VITE_* variables
#    - The frontend uses same-origin API paths:
#        /api/positions
#        /api/market-data
#        /api/analytics
#        /api/news
#    - Nginx inside the frontend container proxies these paths to the correct services.
#
# 2) Local frontend development (without Docker)
#    - Run the frontend using: yarn workspace frontend dev
#    - The Vite dev server proxies /api/* requests to the backend services below.
#
# ---------------------------------------------------------------------------
# Vite dev proxy targets (used only by the Vite development server)
# ---------------------------------------------------------------------------
# These should match the ports where your backend services are running.

VITE_DEV_POSITIONS_PROXY_TARGET=http://localhost:4000
VITE_DEV_MARKET_DATA_PROXY_TARGET=http://localhost:5000
VITE_DEV_ANALYTICS_PROXY_TARGET=http://localhost:7000
VITE_DEV_NEWS_PROXY_TARGET=http://localhost:6500

# ---------------------------------------------------------------------------
# API path overrides (Here if needed)
# ---------------------------------------------------------------------------
# Defaults are correct for both Docker and local development.

# VITE_POSITIONS_API_URL=/api/positions
# VITE_MARKET_DATA_API_URL=/api/market-data
# VITE_ANALYTICS_API_URL=/api/analytics
# VITE_NEWS_API_URL=/api/news

# Override the WebSocket host (default uses same-origin)
# VITE_POSITIONS_WS_URL=