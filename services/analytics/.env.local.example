# =============================================================================
# Analytics Service (LOCAL / NON-DOCKER) Environment
# =============================================================================
# Copy this file to:
#   services/analytics/.env
#
# Then run locally from services/analytics:
#   python -m uvicorn main:app --reload --port %ANALYTICS_PORT%
#   (On PowerShell: $env:ANALYTICS_PORT=7000; python -m uvicorn main:app --reload --port $env:ANALYTICS_PORT)
#
# NOTE:
# - LOCAL runs point to localhost ports.
# - DOCKER runs use the root .env file and service DNS names (e.g. market-data).
# =============================================================================

# Postgres running locally on your machine (not Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wealthwise

# Market Data running locally on your machine
MARKET_DATA_URL=http://localhost:5000/api

# Frontend origin opened in your browser
FRONTEND_ORIGIN=http://localhost:5173

# Service listen port when running locally
ANALYTICS_PORT=7000

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO