# =============================================================================
# Analytics Service — LOCAL / NON-DOCKER environment
# =============================================================================
# Copy to:
#   services/analytics/.env
#
# Run locally from services/analytics:
#   python -m uvicorn main:app --reload --port %ANALYTICS_PORT%
#
# PowerShell example:
#   $env:ANALYTICS_PORT=7000; python -m uvicorn main:app --reload --port $env:ANALYTICS_PORT
#
# Notes:
# - LOCAL runs use localhost ports.
# - DOCKER runs use the root .env (repo root) and Docker DNS names (e.g. db, market-data).
# =============================================================================

# Local Postgres running on your machine (not inside Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wealthwise

# Market Data service running locally on your machine
MARKET_DATA_URL=http://localhost:5000/api

# Browser origin for CORS (where the frontend is opened)
FRONTEND_ORIGIN=http://localhost:5173

# Port this service listens on locally
ANALYTICS_PORT=7000

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO