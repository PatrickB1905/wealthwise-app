# =============================================================================
# Market Data Service (LOCAL / NON-DOCKER) Environment
# =============================================================================
# Copy this file to:
#   services/market-data/.env
#
# Then run locally from services/market-data:
#   python -m uvicorn main:app --reload --port %MARKET_DATA_SERVICE_PORT%
#   (PowerShell example)
#   $env:MARKET_DATA_SERVICE_PORT=5000; python -m uvicorn main:app --reload --port $env:MARKET_DATA_SERVICE_PORT
#
# NOTE:
# - LOCAL runs point to localhost ports.
# - DOCKER runs use the root .env file and docker-compose injected env vars.
# =============================================================================

# Frontend origin opened in your browser
FRONTEND_ORIGIN=http://localhost:5173

# Service listen port when running locally
MARKET_DATA_SERVICE_PORT=5000

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Safety limit (max number of symbols per request from yfinance)
MARKET_DATA_MAX_SYMBOLS=50