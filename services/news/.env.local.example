# =============================================================================
# News Service (LOCAL / NON-DOCKER) Environment
# =============================================================================
# Copy this file to:
#   services/news/.env
#
# Then run locally from services/news:
#   python -m uvicorn main:app --reload --port %NEWS_SERVICE_PORT%
#   (PowerShell) $env:NEWS_SERVICE_PORT=6500; python -m uvicorn main:app --reload --port $env:NEWS_SERVICE_PORT
#
# NOTE:
# - LOCAL runs point to localhost ports.
# - DOCKER runs use the root .env file and injected env vars.
# =============================================================================

# Your NewsAPI key from newsapi.org
NEWS_API_KEY=add_your_news_api_key_here

# Frontend origin opened in your browser
FRONTEND_ORIGIN=http://localhost:5173

# Service listen port when running locally
NEWS_SERVICE_PORT=6500

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
