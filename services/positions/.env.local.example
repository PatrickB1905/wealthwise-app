# =============================================================================
# Positions Service (LOCAL / NON-DOCKER) Environment
# =============================================================================
# Copy to:
#   services/positions/.env
#
# Run locally from services/positions:
#   python -m uvicorn main:app --reload --port 4000
#
# NOTE:
# - LOCAL runs point to localhost ports.
# - DOCKER runs use the root .env file and service DNS names.
# =============================================================================

# Local Postgres running on your machine (not inside Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wealthwise

# Use a strong random value in real deployments (never commit real secrets).
JWT_SECRET=replace_with_a_strong_secret

# Frontend origin opened in your browser
FRONTEND_ORIGIN=http://localhost:5173

# Port this service listens on locally
POSITIONS_PORT=4000

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# How often the service polls for updated prices
PRICE_POLL_INTERVAL_SECONDS=10

# The maximum amount of symbols per user
MAX_SYMBOLS_PER_USER=50 